<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Area Mapper"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- MAP DIMENSIONS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="6dp"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="Map Dimensions"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/widthInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Width (m)"/>

                <EditText
                    android:id="@+id/heightInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Height (m)"/>

                <Button
                    android:id="@+id/setSizeBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set Size"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#6A1B9A"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ACTIONS -->
        <TextView
            android:text="Actions"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Primary Actions"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/scanBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scan"
                android:backgroundTint="#6A1B9A"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/loadBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Load Map"
                android:layout_marginStart="8dp"
                android:backgroundTint="#6A1B9A"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- ADDITIONAL ACTIONS -->
        <TextView
            android:text="Additional Actions"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/exportBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Export CSV"/>

            <Button
                android:id="@+id/debugBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Debug"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- MAP PREVIEW -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#FFFFFF"
            android:elevation="6dp"
            android:layout_marginTop="8dp">

            <!-- IMAGE -->
            <ImageView
                android:id="@+id/mapImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY" />

            <!-- GRID -->
            <com.example.indoornavigation.GridOverlayView
                android:id="@+id/gridView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <Spinner
                android:id="@+id/roomSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <!-- BUTTON -->
            <Button
                android:id="@+id/startScanBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="START SCAN"
                android:layout_gravity="center"
                android:backgroundTint="#6A1B9A"
                android:textColor="#FFFFFF"/>

        </FrameLayout>

        <!-- RESULT -->
        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Results will appear here"
            android:layout_marginTop="12dp"/>

    </LinearLayout>
</ScrollView>